rules_version = '2';

// 예닮교회 — Firestore 보안 규칙
// 핵심: 사용자는 자기 등급(level)을 스스로 못 바꾼다. 승급은 관리자(level 4)만.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // 내 등급 읽기 (문서가 있을 때만 호출)
    function myLevel() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.level;
    }
    // 관리자 = 로그인 + 내 문서 존재 + level 4 이상
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && myLevel() >= 4;
    }
    // 회원 = 로그인 + 내 문서 존재 + level 2 이상 (사랑방 이용 가능)
    function isMember() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && myLevel() >= 2;
    }
    // 방 접근 가능 = 회원이고, (members 없는 공개방(전체방)이거나 / 그 방 members에 포함)
    function canAccessRoom(roomId) {
      return isMember() && (
        !exists(/databases/$(database)/documents/rooms/$(roomId))
        || !('members' in get(/databases/$(database)/documents/rooms/$(roomId)).data)
        || request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members
      );
    }

    // ===== 사용자 문서 =====
    match /users/{uid} {
      // 단일 조회: 본인 또는 관리자
      allow get: if isOwner(uid) || isAdmin();
      // 목록(명부) 조회: 관리자만
      allow list: if isAdmin();

      // 생성: 본인 문서이고, level은 반드시 1(자가 승급 차단)
      allow create: if isOwner(uid)
        && request.resource.data.level == 1;

      // 수정:
      //  - 관리자는 등급 포함 무엇이든 가능(향후 관리자 화면용)
      //  - 본인은 level을 그대로 둔 채로만 수정 가능(이름 등)
      allow update: if isAdmin()
        || (isOwner(uid) && request.resource.data.level == resource.data.level);

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ===== 사랑방 게시판 =====
    match /posts/{postId} {
      // 읽기: 회원(2단계 이상)
      allow read: if isMember();

      // 생성: 회원이며 본인이 작성자. 공지(notice)는 관리자만.
      allow create: if isMember()
        && request.resource.data.authorUid == request.auth.uid
        && (
          request.resource.data.board == 'share'
          || (request.resource.data.board == 'notice' && isAdmin())
        );

      // 수정:
      //  - 작성자 본인 또는 관리자: 전체 수정 가능
      //  - 그 외 회원: 댓글수(commentCount)만 변경 가능(댓글 달기/지우기용)
      allow update: if (isSignedIn() && (resource.data.authorUid == request.auth.uid || isAdmin()))
        || (isMember()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount']));

      // 삭제: 작성자 본인 또는 관리자
      allow delete: if isSignedIn()
        && (resource.data.authorUid == request.auth.uid || isAdmin());

      // ----- 댓글 -----
      match /comments/{commentId} {
        allow read: if isMember();
        allow create: if isMember()
          && request.resource.data.authorUid == request.auth.uid;
        allow delete: if isSignedIn()
          && (resource.data.authorUid == request.auth.uid || isAdmin());
      }
    }

    // ===== 채팅 (전체방 + 1:1/그룹 DM) =====
    match /rooms/{roomId} {
      // 읽기: 공개방(members 없음)은 회원, 그 외는 members에 포함된 사람만. (없는 방은 조회 허용)
      allow read: if isMember() && (
        resource == null
        || !('members' in resource.data)
        || request.auth.uid in resource.data.members
      );
      // 생성: 회원. members가 있으면 본인이 그 안에 포함.
      allow create: if isMember() && (
        !('members' in request.resource.data)
        || request.auth.uid in request.resource.data.members
      );
      // 수정:
      //  - 관리자: 전체 가능
      //  - 그 방 멤버: 마지막 메시지 + 멤버/명단/합류/이름 관리 키만
      //  - 공개방(전체방) 회원: 마지막 메시지 정보만
      allow update: if isAdmin()
        || (
          isMember()
          && ('members' in resource.data)
          && request.auth.uid in resource.data.members
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
               ['lastMessageAt', 'lastMessageText', 'lastMessageBy',
                'type', 'members', 'memberCount', 'roster', 'joined', 'name'])
        )
        || (
          isMember()
          && !('members' in resource.data)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['lastMessageAt', 'lastMessageText', 'lastMessageBy'])
        );
      allow delete: if isAdmin();

      // ----- 메시지 -----
      match /messages/{msgId} {
        allow read: if canAccessRoom(roomId);
        allow create: if canAccessRoom(roomId)
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000;
        // 편집 미지원(수정 차단). 삭제는 작성자 본인 또는 관리자.
        allow delete: if isSignedIn()
          && (resource.data.authorUid == request.auth.uid || isAdmin());
      }

      // ----- 읽은 지점 (회원별 1문서, 본인 것만 기록/갱신) -----
      match /reads/{uid} {
        allow read: if canAccessRoom(roomId);
        allow create, update: if isOwner(uid) && canAccessRoom(roomId);
        allow delete: if isAdmin();
      }
    }

    // ===== 그 외 모든 문서 =====
    // 기본 차단. (헌금·성도 등 상위 단계 데이터는 만들 때 단계별 규칙을 여기에 추가)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
